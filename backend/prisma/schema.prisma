// Prisma + PostgreSQL schema for ESA Detailing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String
  phone         String
  vehicleReg    String
  serviceType   String
  date          DateTime
  timeSlot      String
  depositPaid   Boolean  @default(false)
  createdAt     DateTime @default(now())
}
